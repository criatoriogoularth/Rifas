# Copie este arquivo para .env e preencha os valores (localmente).
# No Render, essas variáveis são configuradas em Settings > Environment.

# String de conexão do PostgreSQL (Render Postgres, Supabase, etc.)
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Defina como "false" apenas se seu Postgres NÃO exigir SSL (ex: local)
PGSSL=true

# Segredo usado para assinar os tokens de sessão (gere uma string longa e aleatória)
JWT_SECRET=troque-por-uma-string-aleatoria-bem-longa

# URL pública da aplicação (usada para montar o webhook do Mercado Pago)
APP_URL=https://seu-app.onrender.com

# Access Token da conta MASTER do Mercado Pago (usado quando uma organização
# ainda não conectou a própria conta). Pegue em https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=

# Se "true" (ou se NODE_ENV != production e essa variável não estiver como "false"),
# o checkout usa um PIX simulado quando não há MP_ACCESS_TOKEN configurado — útil pra
# testar o fluxo completo de compra localmente sem precisar do Mercado Pago ainda.
# NUNCA deixe como "true" em produção.
ALLOW_SIMULATED_PAYMENTS=true

# Credenciais do primeiro usuário superadmin, criadas pelo script de seed
SUPERADMIN_EMAIL=admin@suaplataforma.com
SUPERADMIN_PASSWORD=defina-uma-senha-forte-aqui

# Minutos que um número fica reservado aguardando pagamento antes de ser liberado
RESERVATION_MINUTES=15

NODE_ENV=development
PORT=3000
