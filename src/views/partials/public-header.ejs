<header class="site-header">
  <div class="row">
    <a class="brand" href="/o/<%= org.slug %>/">
      <% if (org.logo_url) { %><img src="<%= org.logo_url %>" style="height:32px;width:auto;border-radius:6px"><% } else { %><span class="dot"></span><%= org.name %><% } %>
    </a>
    <nav class="nav">
      <a href="/o/<%= org.slug %>/">Home</a>
      <a href="/o/<%= org.slug %>/ganhadores">Ganhadores</a>
      <a href="/o/<%= org.slug %>/como-funciona">Como Funciona</a>
    </nav>
    <div class="nav-actions">
      <% if (typeof user !== 'undefined' && user) { %>
        <a class="btn btn-ghost" href="/o/<%= org.slug %>/minha-conta">Minha Conta</a>
        <form method="POST" action="/o/<%= org.slug %>/sair" style="display:inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-ghost" type="submit">Sair</button>
        </form>
      <% } else { %>
        <a class="btn btn-ghost" href="/o/<%= org.slug %>/entrar">Entrar</a>
        <a class="btn btn-primary" href="/o/<%= org.slug %>/cadastrar">Cadastrar</a>
      <% } %>
    </div>
  </div>
</header>
