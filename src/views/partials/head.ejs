<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %><%= typeof org !== 'undefined' && org ? ' — ' + org.name : '' %></title>
<link rel="stylesheet" href="/css/style.css">
<% if (typeof org !== 'undefined' && org && org.favicon_url) { %><link rel="icon" href="<%= org.favicon_url %>"><% } %>

<% if (typeof org !== 'undefined' && org) {
  const fontMap = {
    fraunces: { google: 'Fraunces:opsz,wght@9..144,600;9..144,700', css: "'Fraunces', Georgia, serif" },
    poppins: { google: 'Poppins:wght@600;700', css: "'Poppins', sans-serif" },
    playfair: { google: 'Playfair+Display:wght@600;700', css: "'Playfair Display', Georgia, serif" },
    montserrat: { google: 'Montserrat:wght@600;700', css: "'Montserrat', sans-serif" },
  };
  const chosen = fontMap[org.font_choice] || fontMap.fraunces;
%>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=<%= chosen.google %>&display=swap">
<style>
  :root{
    --brand: <%= org.primary_color || '#0F6B4C' %>;
    --brand-dark: color-mix(in srgb, <%= org.primary_color || '#0F6B4C' %> 80%, black);
    --gold: <%= org.secondary_color || '#D4A72C' %>;
    --gold-soft: color-mix(in srgb, <%= org.secondary_color || '#D4A72C' %> 45%, white);
    --font-display: <%- chosen.css %>;
  }
</style>
<% } %>
